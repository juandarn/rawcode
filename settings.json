{
  "permissions": {
    "deny": [
      "Write(.env*)",
      "Edit(.env*)",
      "Write(**/migrations/**)",
      "Edit(**/migrations/**)",
      "Write(*package-lock.json)",
      "Edit(*package-lock.json)",
      "Write(*yarn.lock)",
      "Edit(*yarn.lock)",
      "Write(*pnpm-lock.yaml)",
      "Edit(*pnpm-lock.yaml)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/plugins/rawcode/statusline.sh"
  }
}
