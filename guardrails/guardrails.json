{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/rawcode/guardrails/protect-sensitive-files.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/plugins/rawcode/guardrails/enforce-read-before-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/rawcode/guardrails/sanitize-commit.sh"
          }
        ]
      }
    ]
  }
}
